{
  "version": 2,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/put$",
      "headers": { "host": "s.jackdehaan.com" },
      "dest": "/api/put"
    },
    {
      "src": "^/([A-Za-z0-9_-]{6,12})$",
      "headers": { "host": "s.jackdehaan.com" },
      "dest": "/api/r/$1"
    },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
