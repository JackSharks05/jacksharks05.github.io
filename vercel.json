{
  "rewrites": [
    {
      "source": "/put",
      "has": [{ "type": "host", "value": "s.jackdehaan.com" }],
      "destination": "/api/put"
    },
    {
      "source": "/:code([A-Za-z0-9_-]{6,12})",
      "has": [{ "type": "host", "value": "s.jackdehaan.com" }],
      "destination": "/api/r/:code"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
