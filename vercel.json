{
  "version": 2,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api/r/([A-Za-z0-9_-]{1,64})$",
      "dest": "/api/r?code=$1"
    },
    {
      "src": "^/put$",
      "headers": { "host": "s.jackdehaan.com" },
      "dest": "/api/put"
    },
    {
      "src": "^/([A-Za-z0-9_-]{1,64})$",
      "headers": { "host": "s.jackdehaan.com" },
      "dest": "/api/r?code=$1"
    },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
