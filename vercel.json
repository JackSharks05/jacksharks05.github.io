{
  "routes": [
    {
      "src": "^/$",
      "headers": { "host": "^s\\.jackdehaan\\.com$" },
      "dest": "/cc/index.html"
    },
    {
      "src": "^/put$",
      "headers": { "host": "^s\\.jackdehaan\\.com$" },
      "dest": "/api/put"
    },
    {
      "src": "^/([^/]+)$",
      "headers": { "host": "^s\\.jackdehaan\\.com$" },
      "dest": "/api/r/$1"
    },
    { "src": "^/cc$", "dest": "/cc/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
