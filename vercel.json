{
  "routes": [
    {
      "src": "^/put$",
      "headers": { "host": "^s\\.jackdehaan\\.com(:\\d+)?$" },
      "dest": "/api/put"
    },
    {
      "src": "^/([A-Za-z0-9_-]{6,12})$",
      "headers": { "host": "^s\\.jackdehaan\\.com(:\\d+)?$" },
      "dest": "/api/r/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
